# ─────────────────────────────────────────────────────────────────────────────
# AuraFlow (open core) — copy to .env and fill in. NEVER commit your real .env.
#
# Generate strong secrets:
#   openssl rand -hex 32
#     → APP_SECRET, JWT_SECRET, POSTGRES_PASSWORD, REDIS_PASSWORD, FLOWER_PASSWORD
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#     → HEALTH_DATA_ENCRYPTION_KEY, BACKUP_ENCRYPTION_KEY
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=production

# ── Postgres / Redis (compose services) ──────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
# The passwords in these URLs MUST match the two above:
DATABASE_URL=postgresql://auraflow:CHANGE_ME@postgres:5432/auraflow
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# ── Core app secrets ─────────────────────────────────────────────────────────
APP_SECRET=CHANGE_ME_32_BYTES_HEX
JWT_SECRET=CHANGE_ME_32_BYTES_HEX
HEALTH_DATA_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
BACKUP_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY
JWT_ALGORITHM=HS256

# ── URLs / branding ──────────────────────────────────────────────────────────
API_URL=https://api.your-domain.com
APP_URL=https://app.your-domain.com
PLATFORM_NAME=AuraFlow
CORS_ORIGINS=https://app.your-domain.com

# ── Frontend build args (Next.js — baked at build time) ──────────────────────
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_APP_URL=https://app.your-domain.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_SENTRY_DSN=

# ── Flower (Celery task monitor) ─────────────────────────────────────────────
FLOWER_PASSWORD=CHANGE_ME

# ── AI / voice (bring your own key in the free build) ────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME
# OPENAI_API_KEY=
# (managed AI without your own keys is a paid AuraFlow Cloud offering)

# ── Email (Purelymail or any SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=hello@example.com
SMTP_FROM_NAME=Your Studio

# ── Billing ──────────────────────────────────────────────────────────────────
# 'self'    : use YOUR own Square/Stripe directly (no platform fee)
# 'managed' : route Square billing through the AuraFlow managed broker (1% fee)
AURAFLOW_BILLING_MODE=self
SQUARE_ENVIRONMENT=production
SQUARE_APPLICATION_ID=
AURAFLOW_BROKER_URL=
AURAFLOW_BROKER_API_KEY=

# ── Backups (optional — Backblaze B2 / any S3-compatible) ────────────────────
# B2_ACCOUNT_ID=
# B2_APPLICATION_KEY=
# B2_ENDPOINT=
# B2_BUCKET_BACKUPS=

# ── Observability (optional) ─────────────────────────────────────────────────
# SENTRY_DSN_API=
# Grafana Agent (infra/grafana-agent/agent.yaml) — only if you wire metrics:
# GRAFANA_PROM_URL=
# GRAFANA_PROM_USER=
# GRAFANA_API_KEY=
LOG_LEVEL=INFO
